#include <iostream>
#include <ctime>
using namespace std;

int main() {
    int n;
    
    cin >> n;
    
    int** arr = new int*[n];
    for (int i = 0; i < n; i++)
        *(arr + i) = new int[n];

    srand(time(0));

    int even = 0;
    int odd = 0;
 
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {

            *(*(arr + i) + j) = rand() % 100;

            cout << *(*(arr + i) + j) << "\t";

            if (*(*(arr + i) + j) % 2 == 0)
                even++;
            else
                odd++;
        }
        cout << endl;
    }

    cout << "Main diagonal:\n";
    for (int i = 0; i < n; i++) {
        cout << *(*(arr + i) + i) << " ";
        
    }

    cout << "\nSecondary diagonal:\n";
    for (int i = 0; i < n; i++) {
        cout << *(*(arr + i) + (n - 1 - i)) << " ";
        
    }

    cout << "\nEven elements: " << even;
    cout << "\nOdd elements: " << odd;

    // for (int i = 0; i < n; i++)
    //     delete[] *(arr + i);

    // delete[] arr;

    return 0;
}
