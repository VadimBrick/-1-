void FlightBooking::printStatus() {
int* ReservedSeatsPercentage = new int;
*ReservedSeatsPercentage = (int)((this->reserved*100)/this->capacity); 
cout << "Flight "<<this->id<<" : "<<this->reserved<<"/"<<this->capacity<<"("<<*ReservedSeatsPercentage<<"%) seats reserved\n";
delete ReservedSeatsPercentage;
}

bool FlightBooking::reserveSeats(int number_of_seats) {
int* MaxSeatsAmount = new int;
*MaxSeatsAmount = (int)((this->capacity*1.05)); 
if ( (number_of_seats+this->reserved)<=*MaxSeatsAmount ) {
    this->reserved = (this->reserved+number_of_seats);
    delete MaxSeatsAmount;
    return true;
}
    else { 
    cout << "Too many seats in total, lower the number so it's less than 105%, "<<number_of_seats<<" & "<<this->reserved<<" out of "<<this->capacity<<"\n"; 
    delete MaxSeatsAmount; 
    return false;
    }
}

bool FlightBooking::cancelReservations(int number_of_seats) {
if ((this->reserved-number_of_seats)<0) {
    this->reserved = 0;
}
    else { this->reserved=(this->reserved-number_of_seats); }
return true;
}

FlightBooking::FlightBooking() {
id = 0; capacity = 0; reserved = 0; 
}
FlightBooking::FlightBooking(int id, int capacity, int reserved) {
int* MaxAllowedSeats = new int;
*MaxAllowedSeats = (int)(capacity*1.05);
if (reserved<0) { reserved = 0; }
if (reserved>*MaxAllowedSeats) {
    cout << "reservations are above 105 percent of total capacity!\n";
    exit(1);
}
else {
this->id=id;
this->capacity=capacity;
this->reserved=reserved;
}
delete MaxAllowedSeats;
}

void FlightBooking::setId(int id) {
this->id = id;
}

