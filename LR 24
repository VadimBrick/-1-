Fraction::Fraction(int numerator, int denominator) {
    this->numerator = numerator;
    this->denominator = denominator;
    this->reduce();
}

string Fraction::toString() {
    
    string FinalString;
    
    if (this->numerator == 0) { return "0"; }
    if (this->denominator == 0) { return to_string(this->numerator); }
    int Negatives=0;
    int EntirelyPositiveNumerator=this->numerator;
    int EntirelyPositiveDenominator=this->denominator;
    if ( this->numerator<0 ) { Negatives++; EntirelyPositiveNumerator=(this->numerator*-1); }
    if ( this->denominator<0 ) { Negatives++; EntirelyPositiveDenominator=(this->denominator*-1); }
    
    if ( EntirelyPositiveNumerator > EntirelyPositiveDenominator ) {
        
        int RemainderOffset = EntirelyPositiveNumerator % EntirelyPositiveDenominator; 
        int ApplicableDividend = (EntirelyPositiveNumerator-RemainderOffset);
        int AmountOfFills = ApplicableDividend / EntirelyPositiveDenominator; 
       
        string StringFills = to_string(AmountOfFills);
        string StringRemainderOffset = to_string(RemainderOffset);
        string StringPositiveDenominator = to_string(EntirelyPositiveDenominator);
        string FractionPortion = "";
        if (RemainderOffset!=0) {
        FinalString = StringFills+" "+StringRemainderOffset+"/"+StringPositiveDenominator;
        }
    else { FinalString = StringFills; }
    }
    else { 
        string StringNumerator = to_string(EntirelyPositiveNumerator);
        string StringDenominator = to_string(EntirelyPositiveDenominator);
        FinalString = StringNumerator+"/"+StringDenominator; 
    }

    if ( Negatives%2 != 0 ) {
    FinalString = "-"+FinalString;
    }
    
    return FinalString;
}
double Fraction::toDouble() {
double NumeratorAdjusted = (double)this->numerator;
double DenominatorAdjusted = (double)this->denominator;
double InDoubleFormatNumber = NumeratorAdjusted/DenominatorAdjusted;
return InDoubleFormatNumber;
}

void Fraction::reduce() {
    
    if ( this->numerator<0 ) { this->SetNumToNegativeAfterRecursion=true; this->numerator=(this->numerator*-1); }
    if ( this->denominator<0 ) { this->SetDenToNegativeAfterRecursion=true; this->denominator=(this->denominator*-1); }
    
    int LowerNumber;
    if ( this->numerator<this->denominator ) { LowerNumber=this->numerator; } else { LowerNumber=this->denominator; }
    
    bool ContinueRecursion = false;
    if ( LowerNumber >= 2 ) {
    for (int i=2;i<=LowerNumber;i++) {
        if ( this->numerator <= 1 || this->denominator <= 1 ) {
            ContinueRecursion=false;
            break;
        }
        else if ( (this->numerator%i) == 0 && (this->denominator%i) == 0 ) {
            this->numerator = (this->numerator/i);
            this->denominator = (this->denominator/i);
            ContinueRecursion=true;
            break;
        }
    }
    }
    else { ContinueRecursion=false; }
    if ( ContinueRecursion == true ) { 
        this->reduce(); 
    }
    else {
        if ( this->SetNumToNegativeAfterRecursion==true ) { this->numerator=(this->numerator*-1); }
        if ( this->SetDenToNegativeAfterRecursion==true ) { this->denominator=(this->denominator*-1); }
    }
}
bool Fraction::isGreaterThan(Fraction that) {
    double ConvertedNum1=(double)this->numerator;
    double ConvertedNum2=(double)that.numerator;
    double ConvertedDen1=(double)this->denominator;
    double ConvertedDen2=(double)that.denominator;
    double ThisFractionValue = ConvertedNum1/ConvertedDen1;
    double ThatFractionValue = ConvertedNum2/ConvertedDen2;
    
    if (ThisFractionValue > ThatFractionValue) { return true; } else { return false; }
}

bool Fraction::isLessThan(Fraction that) {
    double ConvertedNum1=(double)this->numerator;
    double ConvertedNum2=(double)that.numerator;
    double ConvertedDen1=(double)this->denominator;
