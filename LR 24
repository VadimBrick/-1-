    double ThisFractionValue = ConvertedNum1/ConvertedDen1;
    double ThatFractionValue = ConvertedNum2/ConvertedDen2;
    if (ThisFractionValue < ThatFractionValue) { return true; } else { return false; }
} 
bool Fraction::isEqual(Fraction that) {
